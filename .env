# ==========================================
# Futurist E-commerce - Recommendation Service
# LOCAL DEVELOPMENT CONFIGURATION
# ==========================================

# ==========================================
# APPLICATION SETTINGS
# ==========================================
ENVIRONMENT=development
APP_NAME=Futurist Recommendation Service
APP_VERSION=2.1.0
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO
WORKERS=2
RELOAD=true

# ==========================================
# MONGODB DATABASE
# ==========================================
MONGO_URI=mongodb+srv://traoyaya09:vcqgF9ub9r57oq0m@cluster0.lbqbl2z.mongodb.net/futurist_e-commerce
MONGO_DB_NAME=futurist_e-commerce
MONGO_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=20000
MONGO_MAX_RETRY_ATTEMPTS=3
MONGO_RETRY_DELAY_SECONDS=2

# MongoDB Collection Names
MONGO_COLLECTION_PRODUCTS=products
MONGO_COLLECTION_RECOMMENDATION_LOGS=recommendation_logs
MONGO_COLLECTION_INTERACTION_LOGS=interaction_logs

MONGO_COLLECTION_INTERACTIONS=interaction_logs
MIN_INTERACTIONS=3
LATENT_FEATURES=50

IMAGE_MODEL_NAME=ViT-B/32
IMAGE_EMBEDDING_BATCH_SIZE=32
IMAGE_DOWNLOAD_WORKERS=4
IMAGE_DOWNLOAD_TIMEOUT=10
IMAGE_DOWNLOAD_RETRIES=3

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# ==========================================
# CORS SETTINGS (Development - allows all)
# ==========================================
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# ==========================================
# MODEL PATHS & SETTINGS
# ==========================================
COLLABORATIVE_MODEL_PATH=models/hybrid_model.joblib
TEXT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
IMAGE_MODEL_NAME=ViT-B/32

# ==========================================
# RECOMMENDATION SETTINGS
# ==========================================
DEFAULT_NORMALIZE=true
DEFAULT_LIMIT=20
MAX_LIMIT=100

# Scoring weights
WEIGHT_HYBRID=0.3
WEIGHT_TEXT=0.25
WEIGHT_IMAGE=0.15
WEIGHT_INTERACTION=0.2
WEIGHT_FIELD=0.1

# ==========================================
# GPT/AI SETTINGS
# ==========================================
GPTS_API_BASE_URL=https://api.gptsapi.net/v1
GPTS_API_MAX_RETRIES=3
GPTS_API_MODEL=gpt-4o-mini
GPTS_API_TIMEOUT_MS=20000

