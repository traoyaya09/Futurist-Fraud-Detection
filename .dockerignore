# ═══════════════════════════════════════════════════════════════════════════
# Docker Ignore - Fraud Detection System
# ═══════════════════════════════════════════════════════════════════════════
# Files/directories to exclude from Docker build context (speeds up builds)
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Python
# ───────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/
dist/
build/

# ───────────────────────────────────────────────────────────────────────────
# Data & Models (KEEP these - they're needed!)
# ───────────────────────────────────────────────────────────────────────────
# data/creditcard.csv  # Uncomment if you don't need training data in container
# results/             # Uncomment if you don't need results in container

# ───────────────────────────────────────────────────────────────────────────
# Documentation (exclude from image)
# ───────────────────────────────────────────────────────────────────────────
*.md
!README.md  # Keep main README
docs/
*.txt
!requirements.txt  # Keep dependencies

# ───────────────────────────────────────────────────────────────────────────
# Git
# ───────────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ───────────────────────────────────────────────────────────────────────────
# Docker
# ───────────────────────────────────────────────────────────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ───────────────────────────────────────────────────────────────────────────
# IDE
# ───────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ───────────────────────────────────────────────────────────────────────────
# Testing
# ───────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.test.py

# ───────────────────────────────────────────────────────────────────────────
# Logs (will be generated fresh in container)
# ───────────────────────────────────────────────────────────────────────────
logs/*.log
*.log

# ───────────────────────────────────────────────────────────────────────────
# Temporary files
# ───────────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
.cache/
