
# ═══════════════════════════════════════════════════════════════════════════
# Docker Ignore - Fraud Detection System
# ═══════════════════════════════════════════════════════════════════════════
# Files/directories to exclude from Docker build context (speeds up builds)
# CRITICAL: Do NOT block requirements.txt or trained_models/
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Python cache and compiled files
# ───────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ───────────────────────────────────────────────────────────────────────────
# Virtual environments
# ───────────────────────────────────────────────────────────────────────────
env/
venv/
ENV/
.venv/

# ───────────────────────────────────────────────────────────────────────────
# Git files
# ───────────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ───────────────────────────────────────────────────────────────────────────
# IDE and editor files
# ───────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ───────────────────────────────────────────────────────────────────────────
# Environment variables (security)
# ───────────────────────────────────────────────────────────────────────────
.env
.env.*

# ───────────────────────────────────────────────────────────────────────────
# Testing artifacts
# ───────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.test.py

# ───────────────────────────────────────────────────────────────────────────
# Build artifacts (Docker itself)
# ───────────────────────────────────────────────────────────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ───────────────────────────────────────────────────────────────────────────
# Documentation (optional - can be excluded to reduce image size)
# ───────────────────────────────────────────────────────────────────────────
*.md
!README.md

# ───────────────────────────────────────────────────────────────────────────
# Logs (will be generated fresh in container)
# ───────────────────────────────────────────────────────────────────────────
logs/*.log
*.log

# ───────────────────────────────────────────────────────────────────────────
# Temporary files
# ───────────────────────────────────────────────────────────────────────────
*.tmp
*.bak
.cache/

# ───────────────────────────────────────────────────────────────────────────
# Training data (not needed in production - only for local training)
# ───────────────────────────────────────────────────────────────────────────
data/
*.csv

# ───────────────────────────────────────────────────────────────────────────
# IMPORTANT: Do NOT ignore these critical files
# ───────────────────────────────────────────────────────────────────────────
# requirements.txt - MUST be included for pip install
# trained_models/ - MUST be included for model loading
# fraud_detection_service.py - Main API service
# ───────────────────────────────────────────────────────────────────────────

