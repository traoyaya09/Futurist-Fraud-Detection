# ============================================================================
# DOCKER IGNORE - Futurist E-Commerce
# ============================================================================
# Prevents unnecessary files from being copied into Docker images
# Keeps images small and build times fast
# ============================================================================

# ============================================================================
# 🚫 VERSION CONTROL
# ============================================================================
.git
.gitignore
.gitattributes
.github/

# ============================================================================
# 🚫 DOCUMENTATION
# ============================================================================
*.md
README.md
CHANGELOG.md
LICENSE
docs/
documentation/

# ============================================================================
# 🚫 NODE.JS
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn
.pnpm

# ============================================================================
# 🚫 PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
recommendation_service/venv/

# 🔥 HEAVY ML FILES
recommendation_service/text_embeddings/
text_embeddings/
*.npy
*.npz
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5

# Training logs
*.log
training.log
master_training.log

# ============================================================================
# 🚫 BUILD OUTPUTS
# ============================================================================
dist/
build/
out/
.astro/
coverage/
.next/
.nuxt/
.cache/

# ============================================================================
# 🚫 ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.dev.vars*

# ============================================================================
# 🚫 IDE & EDITOR
# ============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ============================================================================
# 🚫 DOCKER
# ============================================================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ============================================================================
# 🚫 CI/CD
# ============================================================================
.github/
.gitlab-ci.yml
.circleci/
azure-pipelines.yml
Jenkinsfile

# ============================================================================
# 🚫 DEPLOYMENT
# ============================================================================
.wrangler/
deploy/
deployment/
*.tar.gz
*.zip

# ============================================================================
# 🚫 TESTING
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.nyc_output/
test/
tests/
**/*.test.js
**/*.spec.js

# ============================================================================
# 🚫 TEMPORARY FILES
# ============================================================================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

