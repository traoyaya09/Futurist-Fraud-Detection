# ============================================================================
# FUTURIST E-COMMERCE - GIT IGNORE
# ============================================================================
# This file prevents heavy files, generated content, and sensitive data
# from being pushed to GitHub
# ============================================================================

# ============================================================================
# 🚫 FRONTEND BUILD & GENERATED FILES
# ============================================================================

# Astro build output
dist/
.astro/

# Node modules
node_modules/

# Logs
